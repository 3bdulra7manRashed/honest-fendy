# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# =============================================================================
# Dependencies
# =============================================================================

# Installed packages (334+ MB in this project). Reproducible via package-lock.json.
/node_modules

# Yarn Plug'n'Play
/.pnp
.pnp.*
.pnp.js

# Yarn Berry (v2+) — ignore cache/state, keep committed release artifacts
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# =============================================================================
# Package manager caches & debug logs
# =============================================================================

# npm
.npm
npm-debug.log*
.npm/_logs/

# yarn
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
yarn-debug.log*
yarn-error.log*
.pnp.*

# pnpm
.pnpm-store
.pnpm-debug.log*

# bun
.bun

# =============================================================================
# Next.js
# =============================================================================

# Build output and dev cache (~144 MB in this project). Regenerated on every build/dev.
/.next/
/out/

# Vercel deployment metadata (linked project IDs, local deploy cache)
.vercel

# =============================================================================
# Production / build artifacts
# =============================================================================

/build
/dist

# =============================================================================
# Environment & secrets
# =============================================================================

# Never commit real secrets (e.g. RESEND_API_KEY). Keep .env.example as the template.
.env
.env.*
!.env.example

# =============================================================================
# Testing & coverage
# =============================================================================

/coverage
*.lcov
.nyc_output

# Playwright / Puppeteer / Cypress artifacts
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/
/cypress/videos/
/cypress/screenshots/

# =============================================================================
# Logs & temporary files
# =============================================================================

*.log
*.err.log
logs/
*.tmp
*.temp
*.swp
*.swo
*~

# =============================================================================
# TypeScript
# =============================================================================

# Incremental build cache
*.tsbuildinfo

# Auto-generated by Next.js on `next dev` / `next build`
next-env.d.ts

# =============================================================================
# Linting & tooling caches
# =============================================================================

.eslintcache
.stylelintcache
.prettiercache
.turbo
.cache
.parcel-cache
.swc/

# =============================================================================
# Editor & IDE
# =============================================================================

.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.code-workspace

# =============================================================================
# Operating system
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =============================================================================
# Security & certificates
# =============================================================================

# Private keys and certificates — never commit
*.pem
*.key
*.p12
*.pfx

# =============================================================================
# Project-specific generated assets
# =============================================================================

# QA / browser-automation screenshots (puppeteer, chrome). Not production assets.
/qa-screenshots/
